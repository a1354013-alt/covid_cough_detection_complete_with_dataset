# Node gateway (production defaults)
NODE_ENV=production
PORT=3000

# Python inference backend origin (reachable from the Node container/network)
# Prefer `PYTHON_API_URL`; `PYTHON_BACKEND_URL` is a supported alias.
PYTHON_API_URL=http://localhost:8000
#PYTHON_BACKEND_URL=http://localhost:8000

# CORS allow-list for the Node gateway (comma-separated origins). REQUIRED in production.
# Example: https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS=http://localhost:3000

# Reverse-proxy trust setting for Express `trust proxy`.
# - unset: dev=false, prod=1
# - true/false: explicit boolean
# - integer: number of proxy hops (recommended in production)
TRUST_PROXY=1

# Gateway-to-python request timeout (milliseconds)
REQUEST_TIMEOUT=60000

# Rate limiting for POST /api/predict (requests per minute, per IP)
RATE_LIMIT_MAX_REQUESTS=30

# Enable SQLite persistence/caching for inference history + stats.
# - true (default): try to use SQLite (falls back to in-memory if dependency missing)
# - false: force in-memory only
ENABLE_DATABASE=true

# Optional path for the SQLite file used by the Node gateway.
# Default: server/data/inferences.db (repo-relative)
DATABASE_PATH=

# Prediction cache TTL (seconds) when database caching is enabled.
CACHE_TTL_SECONDS=3600

# Optional API keys (comma-separated). If unset, API key auth is effectively disabled.
# Example: API_KEYS=dev_key_123,admin_key_456
API_KEYS=

# Optional API key file path (one key per line). Overrides API_KEYS if set.
API_KEY_FILE=

# Optional extra `connect-src` entries appended to CSP (space-separated)
# Example: https://sentry.io wss://realtime.example.com
CSP_CONNECT_SRC_EXTRA=

# Optional ffmpeg command override (used by the gateway for best-effort audio conversion)
# FFMPEG_PATH=/usr/bin/ffmpeg
FFMPEG_PATH=ffmpeg
