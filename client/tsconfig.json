{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": ["vite/client", "node", "vitest/globals"],
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["../shared/*"]
    },
    "outDir": "./dist",
    "skipLibCheck": true
  },
  "include": ["src", "vite-env.d.ts", "../shared/version.ts"],
  "exclude": ["node_modules", "dist", "build"]
}
