# Python inference service (strict startup)

# REQUIRED: path to a trained model file
MODEL_PATH=/app/models/model.pt

# Optional CORS allow-list for Python service (comma-separated). Use explicit origins in production.
# Default \"*\" allows localhost only for development. In production, set explicit origins.
# Example: http://localhost:3000,http://localhost:5173
ALLOWED_ORIGINS=*

# Optional log level (python logging module + uvicorn default level)
LOG_LEVEL=info

