{
  "name": "covid-cough-detection-server",
  "version": "1.0.13",
  "description": "COVID-19 Cough Detection API Server",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "tsx --test src/*.test.ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "busboy": "^1.6.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.3",
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",

    "typescript": "^5.1.3",
    "tsx": "^4.7.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "rimraf": "^6.0.1"
  }
}
